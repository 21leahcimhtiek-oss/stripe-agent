# App
NODE_ENV=production
PORT=3000
APP_URL=https://your-app.vercel.app

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/stripe_agent

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# GitHub
GH_TOKEN=ghp_...
GITHUB_TOKEN=ghp_...

# OAuth
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your-open-id

# Forge API (built-in AI)
BUILT_IN_FORGE_API_URL=https://api.forge.dev
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# Frontend
VITE_APP_ID=stripe-agent
VITE_FRONTEND_FORGE_API_URL=https://api.forge.dev
VITE_FRONTEND_FORGE_API_KEY=your-forge-api-key
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com